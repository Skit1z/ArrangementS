# ===== 应用 =====
APP_ENV=development
APP_SECRET=change-me-app-secret
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:8000
MAX_UPLOAD_MB=20

# ===== 数据库 / 缓存 =====
DATABASE_URL=postgresql+psycopg://scheduler:scheduler@postgres:5432/scheduler
REDIS_URL=redis://redis:6379/0

# ===== 安全（生产务必替换为高强度随机值）=====
JWT_SECRET=change-me-jwt-secret-at-least-32-bytes-long
CSRF_SECRET=change-me-csrf-secret-at-least-32-bytes-long
# base64 编码的 32 字节 AES-256-GCM 密钥，可用 `python -c "from app.core.crypto import generate_key_b64; print(generate_key_b64())"` 生成
FIELD_ENCRYPTION_KEY=

# ===== 令牌与 Cookie =====
ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=14
COOKIE_SECURE=false
# COOKIE_DOMAIN=example.com
CORS_ORIGINS=http://localhost:5173

# ===== 登录限速 =====
LOGIN_MAX_FAILURES=5
LOGIN_LOCK_SECONDS=300

# ===== 文件存储与备份 =====
FILE_STORAGE_PATH=/var/app/files
BACKUP_RETENTION_DAYS=30

# ===== Postgres 容器 =====
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler
